<resources>

    <style name="Widget.Theme.TikTokCloneProject.ActionBar.Fullscreen" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black_overlay</item>
    </style>

    <style name="Widget.Theme.TikTokCloneProject.ButtonBar.Fullscreen" parent="">
        <item name="android:background">@color/black_overlay</item>
        <item name="android:buttonBarStyle">?android:attr/buttonBarStyle</item>
    </style>

    <style name="TopTopFloatingWindow">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Style Pill Button chuẩn TikTok -->
    <style name="tiktok_pill_button" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/fixed_tiktok_grey</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="tiktok_button_red" parent="tiktok_pill_button">
        <item name="backgroundTint">@color/fixed_tiktok_red</item>
    </style>

    <style name="tiktok_button_grey" parent="tiktok_pill_button">
        <item name="backgroundTint">@color/fixed_tiktok_grey</item>
    </style>

    <style name="tiktok_button_transparent" parent="tiktok_pill_button">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="rippleColor">@color/fixed_tiktok_grey</item>
    </style>

    <!-- Style cho nút Tin nhắn (Luôn màu xám) -->
    <style name="tiktok_button_message" parent="tiktok_pill_button">
        <item name="backgroundTint">@color/fixed_tiktok_grey</item>
    </style>

    <style name="tiktok_button_record" parent="Widget.AppCompat.Button">
        <item name="android:gravity">center_vertical|center_horizontal</item>
        <item name="android:background">@drawable/record_button</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:stateListAnimator">@drawable/button_state_list_anim_shrink</item>
    </style>

    <style name="tiktok_button_stop_record" parent="Widget.AppCompat.Button">
        <item name="android:gravity">center_vertical|center_horizontal</item>
        <item name="android:background">@drawable/stop_button</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:stateListAnimator">@drawable/button_state_list_anim_shrink</item>
    </style>

    <style name="rounded_corner">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>